func New{{.ResourceNamePascal}}DataSource() datasource.DataSource {
	return &{{.ResourceNamePascal}}DataSource{}
}

// {{.ResourceNamePascal}}DataSource defines the data source implementation.
type {{.ResourceNamePascal}}DataSource struct {
	client *APIClient
}

// {{.ResourceNamePascal}}DataSourceModel describes the data source data model.
type {{.ResourceNamePascal}}DataSourceModel struct {
{{- range .Fields}}
	{{.GoName}} {{.GoType}} `tfsdk:"{{.Name}}"`
{{- end}}
}

func (d *{{.ResourceNamePascal}}DataSource) Metadata(ctx context.Context, req datasource.MetadataRequest, resp *datasource.MetadataResponse) {
	resp.TypeName = req.ProviderTypeName + "_{{.ResourceName}}"
}

func (d *{{.ResourceNamePascal}}DataSource) Schema(ctx context.Context, req datasource.SchemaRequest, resp *datasource.SchemaResponse) {
	resp.Schema = schema.Schema{
		MarkdownDescription: "{{.ResourceDescription}}",

		Attributes: map[string]schema.Attribute{
{{- template "renderAttributes" .Fields}}
		},
	}
}

func (d *{{.ResourceNamePascal}}DataSource) Configure(ctx context.Context, req datasource.ConfigureRequest, resp *datasource.ConfigureResponse) {
	if req.ProviderData == nil {
		return
	}

	client, ok := req.ProviderData.(*APIClient)
	if !ok {
		resp.Diagnostics.AddError(
			"Unexpected Data Source Configure Type",
			fmt.Sprintf("Expected *APIClient, got: %T. Please report this issue to the provider developers.", req.ProviderData),
		)
		return
	}

	d.client = client
}

func (d *{{.ResourceNamePascal}}DataSource) Read(ctx context.Context, req datasource.ReadRequest, resp *datasource.ReadResponse) {
	var data {{.ResourceNamePascal}}DataSourceModel

	resp.Diagnostics.Append(req.Config.Get(ctx, &data)...)
	if resp.Diagnostics.HasError() {
		return
	}

{{- if .Read}}
	url := d.client.Endpoint + "{{.Read.Path}}"
{{- if .PathParam}}
	url = strings.Replace(url, "{{"{"}}{{.PathParam}}{{"}"}}", data.{{.PathParamGo}}.ValueString(), 1)
{{- end}}

	httpReq, err := http.NewRequestWithContext(ctx, "{{.Read.Method}}", url, nil)
	if err != nil {
		resp.Diagnostics.AddError("Request Error", fmt.Sprintf("Unable to create request for {{.ResourceName}}: %s", err))
		return
	}

	httpResp, err := d.client.HTTPClient.Do(httpReq)
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to read {{.ResourceName}}: %s", err))
		return
	}
	defer httpResp.Body.Close()

	respBody, err := io.ReadAll(httpResp.Body)
	if err != nil {
		resp.Diagnostics.AddError("Read Error", fmt.Sprintf("Unable to read response for {{.ResourceName}}: %s", err))
		return
	}

	var envelope {{.ResourceNamePascal}}APIEnvelope
	if err := json.Unmarshal(respBody, &envelope); err != nil {
		resp.Diagnostics.AddError("Parse Error", fmt.Sprintf("Unable to parse response for {{.ResourceName}}: %s", err))
		return
	}

	if !envelope.Success {
		resp.Diagnostics.AddError(envelope.Error.Code, envelope.Error.Message)
		return
	}

	r := &{{.ResourceNamePascal}}Resource{}
	r.fromAPIModel(&envelope.Data, (*{{.ResourceNamePascal}}ResourceModel)(&data))
{{- else}}
	resp.Diagnostics.AddError("Not Implemented", "Read is not available for {{.ResourceName}}")
	return
{{- end}}

	tflog.Trace(ctx, "read {{.ResourceName}} data source")
	resp.Diagnostics.Append(resp.State.Set(ctx, &data)...)
}
