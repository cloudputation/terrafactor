func (r *{{.ResourceNamePascal}}EphemeralResource) Metadata(_ context.Context, req ephemeral.MetadataRequest, resp *ephemeral.MetadataResponse) {
	resp.TypeName = req.ProviderTypeName + "_{{.ResourceName}}"
}

func (r *{{.ResourceNamePascal}}EphemeralResource) Schema(ctx context.Context, _ ephemeral.SchemaRequest, resp *ephemeral.SchemaResponse) {
	resp.Schema = schema.Schema{
		MarkdownDescription: "{{.ResourceDescription}}",

		Attributes: map[string]schema.Attribute{
{{- template "renderAttributes" .Fields}}
		},
	}
}

func (r *{{.ResourceNamePascal}}EphemeralResource) Configure(ctx context.Context, req ephemeral.ConfigureRequest, resp *ephemeral.ConfigureResponse) {
	if req.ProviderData == nil {
		return
	}

	client, ok := req.ProviderData.(*APIClient)
	if !ok {
		resp.Diagnostics.AddError(
			"Unexpected Ephemeral Resource Configure Type",
			fmt.Sprintf("Expected *APIClient, got: %T. Please report this issue to the provider developers.", req.ProviderData),
		)
		return
	}

	r.client = client
}

func (r *{{.ResourceNamePascal}}EphemeralResource) Open(ctx context.Context, req ephemeral.OpenRequest, resp *ephemeral.OpenResponse) {
	var data {{.ResourceNamePascal}}EphemeralResourceModel

	resp.Diagnostics.Append(req.Config.Get(ctx, &data)...)
	if resp.Diagnostics.HasError() {
		return
	}

{{- if .Read}}
	url := r.client.Endpoint + "{{.Read.Path}}"
{{- if .PathParam}}
	url = strings.Replace(url, "{{"{"}}{{.PathParam}}{{"}"}}", data.{{.PathParamGo}}.ValueString(), 1)
{{- end}}

	httpReq, err := http.NewRequestWithContext(ctx, "{{.Read.Method}}", url, nil)
	if err != nil {
		resp.Diagnostics.AddError("Request Error", fmt.Sprintf("Unable to create request for {{.ResourceName}}: %s", err))
		return
	}

	httpResp, err := r.client.HTTPClient.Do(httpReq)
	if err != nil {
		resp.Diagnostics.AddError("Client Error", fmt.Sprintf("Unable to open {{.ResourceName}}: %s", err))
		return
	}
	defer httpResp.Body.Close()

	respBody, err := io.ReadAll(httpResp.Body)
	if err != nil {
		resp.Diagnostics.AddError("Read Error", fmt.Sprintf("Unable to read response for {{.ResourceName}}: %s", err))
		return
	}

	var envelope {{.ResourceNamePascal}}APIEnvelope
	if err := json.Unmarshal(respBody, &envelope); err != nil {
		resp.Diagnostics.AddError("Parse Error", fmt.Sprintf("Unable to parse response for {{.ResourceName}}: %s", err))
		return
	}

	if !envelope.Success {
		resp.Diagnostics.AddError(envelope.Error.Code, envelope.Error.Message)
		return
	}

	res := &{{.ResourceNamePascal}}Resource{}
	res.fromAPIModel(&envelope.Data, (*{{.ResourceNamePascal}}ResourceModel)(&data))
{{- else}}
	resp.Diagnostics.AddError("Not Implemented", "Open is not available for {{.ResourceName}}")
	return
{{- end}}

	resp.Diagnostics.Append(resp.Result.Set(ctx, &data)...)
}
