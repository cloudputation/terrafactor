// APIClient wraps *http.Client with the configured API endpoint.
type APIClient struct {
	HTTPClient *http.Client
	Endpoint   string
}

// Ensure {{.ProviderNamePascal}}Provider satisfies various provider interfaces.
var _ provider.Provider = &{{.ProviderNamePascal}}Provider{}
var _ provider.ProviderWithEphemeralResources = &{{.ProviderNamePascal}}Provider{}

// {{.ProviderNamePascal}}Provider defines the provider implementation.
type {{.ProviderNamePascal}}Provider struct {
	// version is set to the provider version on release, "dev" when the
	// provider is built and ran locally, and "test" when running acceptance
	// testing.
	version string
}

// {{.ProviderNamePascal}}ProviderModel describes the provider data model.
type {{.ProviderNamePascal}}ProviderModel struct {
	Endpoint types.String `tfsdk:"endpoint"`
}

func (p *{{.ProviderNamePascal}}Provider) Metadata(ctx context.Context, req provider.MetadataRequest, resp *provider.MetadataResponse) {
	resp.TypeName = "{{.ProviderName}}"
	resp.Version = p.version
}

func (p *{{.ProviderNamePascal}}Provider) Schema(ctx context.Context, req provider.SchemaRequest, resp *provider.SchemaResponse) {
	resp.Schema = schema.Schema{
		Attributes: map[string]schema.Attribute{
			"endpoint": schema.StringAttribute{
				MarkdownDescription: "API endpoint for the {{.ProviderNamePascal}} provider",
				Optional:            true,
			},
		},
	}
}

func (p *{{.ProviderNamePascal}}Provider) Configure(ctx context.Context, req provider.ConfigureRequest, resp *provider.ConfigureResponse) {
	var data {{.ProviderNamePascal}}ProviderModel

	resp.Diagnostics.Append(req.Config.Get(ctx, &data)...)

	if resp.Diagnostics.HasError() {
		return
	}

	endpoint := strings.TrimRight(data.Endpoint.ValueString(), "/")

	client := &APIClient{
		HTTPClient: http.DefaultClient,
		Endpoint:   endpoint,
	}
	resp.DataSourceData = client
	resp.ResourceData = client
}

